type Query {
    books : [Book!]!
    book(id: ID!): Book!
    authors: [Author!]!
    author(id: ID!): Author
}

type Book {
    id: ID!
    title: String!
    author: Author
}

# object type
type Author {
    id: ID!
    name: String!
    books: [Book!]!
}

input BookInput {
    title: String!
    authorId: Int!
}